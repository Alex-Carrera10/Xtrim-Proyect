// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum LeadStatus {
  NUEVO
  CONTACTADO
  EN_GESTION
  GANADO
  PERDIDO
}

enum ActivityType {
  NOTA
  LLAMADA
  WHATSAPP
  REUNION
  EMAIL
}

model Lead {
  id             String     @id @default(uuid())
  name           String
  email          String?
  phone          String
  province       String
  description    String?
  status         LeadStatus
  valor_estimado Float
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  activities     Activity[]
}

model Activity {
  id        String       @id @default(uuid())
  leadId    String
  content   String
  type      ActivityType
  createdAt DateTime     @default(now())
  lead      Lead         @relation(fields: [leadId], references: [id])
}

model Product {
  id          String   @id @default(uuid())
  title       String
  price       Decimal  @db.Decimal(10, 2)
  category    String
  features    String[]
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
